# Anime News Bot Environment Variables
# Copy this file to .env and fill in your actual API keys

# Groq API (for script generation with Llama)
GROQ_API_KEY=your_groq_api_key_here

# Pexels API (for fetching anime-related images)
PEXELS_API_KEY=your_pexels_api_key_here

# Google YouTube API (for uploading videos)
# This should be a JSON string from your Google Cloud Console
YOUTUBE_CLIENT_SECRETS='{"installed":{"client_id":"...","client_secret":"...","auth_uri":"...","token_uri":"..."}}'
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token_here

# Optional: Gemini API (if planning to use it)
GEMINI_API_KEY=your_gemini_api_key_here
